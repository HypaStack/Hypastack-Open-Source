# Hypastack environment variables
#
# Copy this file to .env and fill in the values below.
# Generate a strong random secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"


# ===== Database (PostgreSQL, required) =====

# Option A: a single connection string. If set, it takes precedence over the
# individual DB_* fields below.
# DATABASE_URL=postgres://user:password@localhost:5432/hypastack

# Option B: individual connection fields (used when DATABASE_URL is not set).
DB_HOST=localhost
DB_PORT=5432
DB_USER=hypastack
DB_PASSWORD=
DB_NAME=hypastack
# Set to "true" to require SSL. Most managed Postgres providers need this.
DB_SSL=false


# ===== Redis (optional) =====

# Used as a fast cache layer in front of Postgres. If Redis is unreachable the
# app falls back to Postgres on its own, so the default is fine for local dev.
REDIS_URL=redis://127.0.0.1:6379


# ===== Core secrets (required) =====

# Signs auth tokens and is also the key used to hash IP addresses. The app
# refuses to start without it. Use a long random string.
JWT_SECRET=

# Signs short-lived file proxy tokens. Falls back to JWT_SECRET if left empty.
PROXY_SECRET=

# Encrypts stored filenames. Must be a 64-character hex string (32 bytes).
FILENAME_ENCRYPTION_KEY=

# Encrypts sensitive fields at rest with AES-256. Must be exactly 32 characters.
ENCRYPTION_KEY=

# Bearer token that protects the cron cleanup endpoint (/api/v2/cron/cleanup).
ADMIN_SECRET_KEY=


# ===== Cloudflare R2 (object storage, required) =====

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public domain that serves CDN assets, for example r2.hypastack.com
R2_CDN_DOMAIN=
# Optional R2 jurisdiction such as "eu". Leave blank for the global endpoint.
R2_JURISDICTION=


# ===== Cloudflare Turnstile (bot protection, required) =====

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# ===== App =====

# Public base URL of the app. Used to build share links and absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Number of trusted proxies in front of the app when reading X-Forwarded-For.
# Behind Cloudflare this is usually 1.
TRUSTED_PROXY_COUNT=1


# ===== Split API host (optional) =====
# Leave these unset to serve the API same-origin under /api/v2 (the default).
# Set them to serve the API from a separate host, e.g. https://api.example.com.

# Base URL the browser uses for API calls. Include the version path.
# NEXT_PUBLIC_API_BASE=https://api.example.com/v2

# Comma-separated origins allowed to call the API cross-origin (CORS + guard).
# Defaults to NEXT_PUBLIC_APP_URL when unset.
# API_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Cookie Domain so auth cookies are shared across the app and api subdomains.
# API_ALLOWED_ORIGINS above should match. Unset = host-only cookies.
# COOKIE_DOMAIN=.example.com

# Origin the server uses for internal API calls (SSR/OG images). Bypasses the
# public edge; defaults to NEXT_PUBLIC_APP_URL when unset.
# INTERNAL_API_ORIGIN=http://127.0.0.1:3000


# ===== Optional integrations =====

# Discord webhook that receives feedback submissions.
DISCORD_FEEDBACK_WEBHOOK=

# Better Stack heartbeat URLs for uptime monitoring. All optional.
BETTERSTACK_DB_HEALTH=
BETTERSTACK_AUTH_HEARTBEAT=
BETTERSTACK_CSRF=
BETTERSTACK_R2_RESPONSE=
BETTERSTACK_MAIN_PAGE=


# ===== Cloudflare Worker: workers/r2-gateway (separate deploy) =====

# Not read by the Next app. Set this as a Worker secret with wrangler, not here.
# AVATAR_SIGNING_SECRET=
