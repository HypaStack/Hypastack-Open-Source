{erl_opts, [debug_info]}.

{deps, [
    {epgsql, "4.7.1"}
]}.

{relx, [
    {release, {hypasched, "0.1.0"}, [hypasched]},
    {vm_args, "config/vm.args"},
    {sys_config, "config/sys.config"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {include_src, false},
            {debug_info, strip}
        ]}
    ]}
]}.
